{
    "lesson": [
        {
            "text": "Thank you.",
            "translations": {
                "Somali": "Mahadsanid."
            }
        },
        {
            "text": "Thanks.",
            "translations": {
                "Somali": "Mahadsanid."
            }
        },
        {
            "text": "Thank you very much.",
            "translations": {
                "Somali": "Aad baad u mahadsantahay."
            }
        },
        {
            "text": "Thanks a lot!",
            "translations": {
                "Somali": "Mahadsanid aad u badan!"
            }
        },
        {
            "text": "Many thanks.",
            "translations": {
                "Somali": "Aad baad u mahadsantahay."
            }
        },
        {
            "text": "Sincerely thanks.",
            "translations": {
                "Somali": "Si daacad ah mahadsanid."
            }
        },
        {
            "text": "Thank you so much!",
            "translations": {
                "Somali": "Aad ayaad u mahadsan tahay!"
            }
        },
        {
            "text": "Thanks a million for your help.",
            "translations": {
                "Somali": "Waxaad uga mahadsantahay caawimadaada malaayiin jeer."
            }
        },
        {
            "text": "I really appreciate your help.",
            "translations": {
                "Somali": "Runtii waan ka mahadcelinayaa caawimadaada."
            }
        },
        {
            "text": "You are so kind.",
            "translations": {
                "Somali": "Aad baad u naxariis badan tahay."
            }
        },
        {
            "text": "I don’t know how to express my thanks.",
            "translations": {
                "Somali": "Ma garanayo sida aan u muujiyo mahadcelintayda."
            }
        },
        {
            "text": "There are no words to show my appreciation!",
            "translations": {
                "Somali": "Ma jiraan erayo aan ku muujiyo mahadcelintayda!"
            }
        },
        {
            "text": "What you’ve done means a lot to me.",
            "translations": {
                "Somali": "Waxaad sameysay wax weyn ayey ii tahay."
            }
        },
        {
            "text": "That’s so kind of you.",
            "translations": {
                "Somali": "Taas waa mid aad u naxariis badan."
            }
        },
        {
            "text": "You’ve made my day.",
            "translations": {
                "Somali": "Waxaad ka dhigtay maalintayda mid farxad leh."
            }
        },
        {
            "text": "I owe you a great deal.",
            "translations": {
                "Somali": "Wax badan ayaan kaa qabo."
            }
        },
        {
            "text": "Thank you from the bottom of my heart for everything.",
            "translations": {
                "Somali": "Waxaan kaaga mahadcelinayaa qalbigayga hoostiisa wax walba."
            }
        },
        {
            "text": "How can I ever possibly thank you?",
            "translations": {
                "Somali": "Sidee baan kuugu mahadcelin karaa?"
            }
        },
        {
            "text": "You’re welcome!",
            "translations": {
                "Somali": "Soo dhowow!"
            }
        },
        {
            "text": "It was my pleasure.",
            "translations": {
                "Somali": "Waxay ahayd farxadayda."
            }
        },
        {
            "text": "My pleasure.",
            "translations": {
                "Somali": "Farxad ayey ii tahay."
            }
        },
        {
            "text": "Don’t mention it.",
            "translations": {
                "Somali": "Ha sheegin."
            }
        },
        {
            "text": "Forget it.",
            "translations": {
                "Somali": "Iloow."
            }
        },
        {
            "text": "No big deal.",
            "translations": {
                "Somali": "Ma aha wax weyn."
            }
        },
        {
            "text": "It’s was nothing.",
            "translations": {
                "Somali": "Ma jirin waxba."
            }
        },
        {
            "text": "Think nothing of it.",
            "translations": {
                "Somali": "Ha ka fikirin."
            }
        },
        {
            "text": "I’m glad that I can help you.",
            "translations": {
                "Somali": "Waan ku faraxsanahay inaan ku caawin karo."
            }
        }
    ]
}
