            }
        },
        {
            "title": "Repeat out loud",
            "text": "Long time no see.",
            "translations": {
                "Somali": "Waa waqti dheer la arkin"
            }
        },
        {
            "title": "Repeat out loud",
            "text": "It’s been a while.",
